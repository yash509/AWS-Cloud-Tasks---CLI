aws ec2 describe-vpcs \
  --filters "Name=tag:Name,Values=devops-pub-vpc" \
  --query "Vpcs[0].VpcId" \
  --output text
  
  
🔹 Get Internet Gateway (IGW) ID

aws ec2 describe-internet-gateways \
  --filters "Name=tag:Name,Values=devops-pub-igw" \
  --query "InternetGateways[0].InternetGatewayId" \
  --output text


🔹 Get Public Route Table (PUB RT) ID

aws ec2 describe-route-tables \
  --filters "Name=tag:Name,Values=devops-pub-rt" \
  --query "RouteTables[0].RouteTableId" \
  --output text


🔹 (Optional) Get Subnet ID


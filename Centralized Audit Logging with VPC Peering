  --owners 099720109477 \
  --filters "Name=name,Values=ubuntu/images/hvm-ssd/ubuntu-*-amd64-server-*" \
  --query 'Images[*].[ImageId,Name,CreationDate]' \
  --region <REGION> \
  --output table

